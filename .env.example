# Database (Neon) — https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Auth (Better Auth)
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# File Storage (Vercel Blob — auto-injected when you connect Blob in Vercel dashboard)
BLOB_READ_WRITE_TOKEN=

# ── AI Provider Config ────────────────────────────────────────────────────────
# LLM_PROVIDER options:    anthropic | openai | google | ollama
# EMBEDDING_PROVIDER options: openai | google | ollama
# Model names are optional — each provider has a sensible default.
LLM_PROVIDER=ollama
LLM_MODEL=tinyllama

EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# ── AI API Keys (only needed if switching away from Ollama) ───────────────────
# GOOGLE_GENERATIVE_AI_API_KEY=    # https://aistudio.google.com → Get API Key
# OPENAI_API_KEY=                  # https://platform.openai.com → API Keys
# ANTHROPIC_API_KEY=               # https://console.anthropic.com → API Keys

# Vector DB (Pinecone) — https://pinecone.io
# Create index: name=parsed, dims=768 (google) or 1536 (openai), metric=cosine
PINECONE_API_KEY=
PINECONE_INDEX_NAME=parsed

# Google OAuth (optional — only needed for "Sign in with Google")
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend) — https://resend.com → API Keys
RESEND_API_KEY=

# Inngest — https://app.inngest.com → Your App → API Keys
# Leave blank for local dev (Inngest dev server handles it automatically)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Pusher — https://dashboard.pusher.com → Channels → Your App → App Keys
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
